<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">
    <!-- 右键菜单 -->
    <system:String x:Key="MOpen">打开</system:String>
    <system:String x:Key="MSett">设置</system:String>
    <system:String x:Key="MSLay">覆盖扬声器布局</system:String>
    <system:String x:Key="MWiri">扬声器接线指南</system:String>
    <system:String x:Key="MDiag">诊断</system:String>
    <system:String x:Key="MRest">重启服务器</system:String>
    <system:String x:Key="MLErr">上次断开连接的原因</system:String>
    <system:String x:Key="MExit">退出</system:String>

    <!-- 主窗口 -->
    <system:String x:Key="SProc">正在处理...</system:String>
    <system:String x:Key="SWait">正在等待媒体播放器...</system:String>
    <system:String x:Key="SNoSv">CavernPipe服务器未运行。</system:String>

    <!-- 错误提示 -->
    <system:String x:Key="NDisc">媒体播放器已断开连接。</system:String>
    <system:String x:Key="NLErr">自上次连接以来没有断开过。</system:String>
    <system:String x:Key="ERest">CavernPipe服务器已在运行并准备好播放。</system:String>
    <system:String x:Key="EServ">CavernPipe服务器正在重启中。</system:String>
    <system:String x:Key="EPipe">CavernPipe服务器在3秒内未能启动。请确保没有名为CavernPipe的命名管道，并使用系统托盘上CavernPipe图标的右键菜单重启管道。</system:String>
    <system:String x:Key="WSLay">您确定要将系统上的Cavern声道布局更改为{0}吗？</system:String>
    <system:String x:Key="WSLaC">更改成功。别忘了，要获得Cavern体验，您必须按照 设置->扬声器接线指南 中的说明连接扬声器！</system:String>
</ResourceDictionary>
